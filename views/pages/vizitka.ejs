<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | fcfortuna.by</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/ticker') %>
  <%- include('../partials/header') %>
  <main>
    <div class="page-header"><div class="container"><h1><%= title %></h1></div></div>
    <div class="container section" style="padding-top:0;">
      <% sections.forEach(function(s) { %>
        <article class="card" style="margin-bottom:1.5rem;padding:2rem;">
          <h2 style="color:var(--blue);margin-bottom:1rem;"><%= s.title %></h2>
          <div style="white-space:pre-line;"><%= s.body %></div>
        </article>
      <% }); %>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
