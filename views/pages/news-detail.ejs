<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | fcfortuna.by</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/ticker') %>
  <%- include('../partials/header') %>
  <main>
    <div class="page-header page-header--slim">
      <div class="container">
        <a href="/blog" class="page-header__back">← Все новости</a>
      </div>
    </div>
    <div class="container section" style="padding-top:0;">
      <article class="news-article">
        <% if (coverImage) { %>
          <img class="news-article__cover" src="<%= coverImage %>" alt="<%= article.title %>" loading="eager">
        <% } else { %>
          <div class="news-article__cover news-article__cover--placeholder"></div>
        <% } %>
        <div class="news-article__body">
          <div class="news-article__date"><%= formatDateRu(article.published_at) %></div>
          <h1 class="news-article__title"><%= article.title %></h1>
          <div class="news-article__content"><%- bodyHtml %></div>
        </div>
      </article>
      <p class="news-article__footer">
        <a href="/blog" class="btn btn--outline">← Все новости</a>
      </p>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
