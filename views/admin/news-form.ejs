<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <div class="admin-main">
      <h1><%= title %></h1>
      <form class="form-card form-card--wide" method="post" action="<%= article ? '/admin/news/' + article.id : '/admin/news' %>" id="news-form">
        <div class="form-group">
          <label>Заголовок</label>
          <input type="text" name="title" value="<%= article ? article.title : '' %>" required>
        </div>
        <div class="form-group">
          <label>Категория (для URL)</label>
          <input type="text" name="category" value="<%= article ? article.category : 'novosti' %>">
        </div>
        <div class="form-group">
          <label>Краткое описание</label>
          <textarea name="excerpt"><%= article ? (article.excerpt || '') : '' %></textarea>
        </div>
        <div class="form-group">
          <label>Картинки</label>
          <div class="image-dropzone" id="image-dropzone">
            <input type="file" id="image-file-input" accept="image/jpeg,image/png,image/gif,image/webp" multiple hidden>
            <p class="image-dropzone__title">Перетащите изображения сюда</p>
            <p class="image-dropzone__hint">или <button type="button" class="image-dropzone__browse" id="image-browse-btn">выберите файлы</button></p>
            <p class="image-dropzone__status" id="image-dropzone-status" hidden></p>
          </div>
          <div class="image-dropzone__previews" id="image-previews"></div>
        </div>
        <div class="form-group">
          <label>Текст</label>
          <textarea name="body" id="news-body" style="min-height:240px;" required><%= article ? article.body : '' %></textarea>
          <p class="form-hint">Можно перетащить картинку прямо в поле текста — она вставится в место курсора.</p>
        </div>
        <div class="form-group">
          <label>Дата публикации</label>
          <input type="datetime-local" name="published_at" value="<%= article ? article.published_at.replace(' ', 'T').substring(0,16) : '' %>" required>
        </div>
        <div class="form-check">
          <input type="checkbox" name="is_pinned" id="is_pinned" <%= article && article.is_pinned ? 'checked' : '' %>>
          <label for="is_pinned">Закрепить</label>
        </div>
        <div class="btn-group">
          <button type="submit" class="btn btn--primary">Сохранить</button>
          <a href="/admin/news" class="btn btn--outline">Отмена</a>
        </div>
      </form>
    </div>
  </div>
  <script src="/js/admin-news-images.js"></script>
</body>
</html>
