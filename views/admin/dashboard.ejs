<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <div class="admin-main">
      <h1><%= title %></h1>
      <div class="admin-stats">
        <div class="stat-card"><div class="stat-card__value"><%= stats.news %></div><div class="stat-card__label">Новостей</div></div>
        <div class="stat-card"><div class="stat-card__value"><%= stats.players %></div><div class="stat-card__label">Игроков</div></div>
        <div class="stat-card"><div class="stat-card__value"><%= stats.groups %></div><div class="stat-card__label">Групп</div></div>
        <div class="stat-card"><div class="stat-card__value"><%= stats.schedule %></div><div class="stat-card__label">Месяцев расписания</div></div>
        <div class="stat-card"><div class="stat-card__value"><%= stats.videos %></div><div class="stat-card__label">Видео</div></div>
      </div>
      <div class="btn-group">
        <a href="/admin/news/new" class="btn btn--primary">+ Новость</a>
        <a href="/admin/players/new" class="btn btn--secondary">+ Игрок</a>
        <a href="/admin/schedule" class="btn btn--secondary">Расписание</a>
        <a href="/admin/settings" class="btn btn--outline">Текст набора</a>
      </div>
    </div>
  </div>
</body>
</html>
