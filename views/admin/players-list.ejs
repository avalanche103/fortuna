<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <div class="admin-main">
      <div class="admin-header">
        <h1><%= title %></h1>
        <a href="/admin/players/new" class="btn btn--primary">+ Добавить</a>
      </div>
      <table class="admin-table">
        <thead><tr><th>Имя</th><th>Группа / статус</th><th></th></tr></thead>
        <tbody>
          <% players.forEach(function(p) { %>
            <tr>
              <td><%= p.name %></td>
              <td><%= p.is_graduate ? 'Воспитанник' : 'Игрок' %></td>
              <td><a href="/admin/players/<%= p.id %>/edit" class="btn btn--outline">Изменить</a></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
