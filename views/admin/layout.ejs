<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Админ</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar__brand">ФК Фортуна</div>
      <nav class="admin-nav">
        <a href="/admin">Дашборд</a>
        <a href="/admin/news">Новости</a>
        <a href="/admin/players">Игроки</a>
        <a href="/admin/videos">Видео</a>
        <a href="/admin/vizitka">Визитка</a>
        <a href="/admin/settings">Настройки</a>
        <a href="/" target="_blank">Открыть сайт</a>
      </nav>
      <form action="/admin/logout" method="post" style="padding:1rem 1.25rem;margin-top:2rem;">
        <button type="submit" class="btn btn--outline" style="width:100%;color:#fff;border-color:rgba(255,255,255,0.3);">Выйти</button>
      </form>
    </aside>
    <div class="admin-main">
      <div class="admin-header">
        <h1><%= title %></h1>
      </div>
      <%- body %>
    </div>
  </div>
</body>
</html>
