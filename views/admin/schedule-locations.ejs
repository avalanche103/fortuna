<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <main class="admin-main">
      <div class="admin-header">
        <div>
          <h1><%= title %></h1>
          <p class="admin-subtitle">Цвет, название и адрес отображаются у занятий.</p>
        </div>
        <a class="btn btn--outline" href="/admin/schedule">К расписанию</a>
      </div>

      <section class="form-card schedule-location-create">
        <h2>Новая площадка</h2>
        <form action="/admin/schedule/locations" method="post" class="schedule-location-form">
          <div class="form-group"><label>Название</label><input name="name" required maxlength="100"></div>
          <div class="form-group"><label>Адрес</label><input name="address" maxlength="200"></div>
          <div class="form-group"><label>Цвет метки</label><input type="color" name="color" value="#6b7280" required></div>
          <div class="form-group"><label>Порядок</label><input type="number" name="sort_order" value="100"></div>
          <label class="form-check"><input type="checkbox" name="is_active" value="1" checked> Активна</label>
          <button class="btn btn--primary" type="submit">Добавить</button>
        </form>
      </section>

      <div class="schedule-locations-list">
        <% locations.forEach(function(location) { %>
          <section class="form-card schedule-location-card <%= location.is_active ? '' : 'is-inactive' %>">
            <div class="schedule-location-card__heading">
              <span class="schedule-location-swatch" style="--location-color:<%= location.color %>"></span>
              <h2><%= location.name %></h2>
            </div>
            <form action="/admin/schedule/locations/<%= location.id %>" method="post" class="schedule-location-form">
              <div class="form-group"><label>Название</label><input name="name" value="<%= location.name %>" required maxlength="100"></div>
              <div class="form-group"><label>Адрес</label><input name="address" value="<%= location.address %>" maxlength="200"></div>
              <div class="form-group"><label>Цвет метки</label><input type="color" name="color" value="<%= location.color %>" required></div>
              <div class="form-group"><label>Порядок</label><input type="number" name="sort_order" value="<%= location.sort_order %>"></div>
              <label class="form-check"><input type="checkbox" name="is_active" value="1" <%= location.is_active ? 'checked' : '' %>> Активна</label>
              <button class="btn btn--secondary" type="submit">Сохранить</button>
            </form>
          </section>
        <% }); %>
      </div>
    </main>
  </div>
</body>
</html>
