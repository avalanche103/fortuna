<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Oswald:wght@600&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <div class="admin-main">
      <h1><%= title %></h1>
      <form class="form-card" method="post" action="/admin/videos" style="margin-bottom:2rem;">
        <div class="form-group">
          <label>Название</label>
          <input type="text" name="title" placeholder="Подтянется с YouTube, если оставить пустым">
        </div>
        <div class="form-group"><label>YouTube URL</label><input type="url" name="youtube_url" required></div>
        <div class="form-group"><label>Порядок</label><input type="number" name="sort_order" value="0"></div>
        <button type="submit" class="btn btn--primary">Добавить</button>
      </form>
      <table class="admin-table">
        <thead><tr><th>Название</th><th>URL</th><th></th></tr></thead>
        <tbody>
          <% videos.forEach(function(v) { %>
            <tr>
              <td><%= v.title %></td>
              <td><a href="<%= v.youtube_url %>" target="_blank"><%= v.youtube_url %></a></td>
              <td>
                <form action="/admin/videos/<%= v.id %>/delete" method="post" onsubmit="return confirm('Удалить?')">
                  <button type="submit" class="btn btn--danger">Удалить</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
