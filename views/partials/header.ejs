<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__brand">
      <a href="/" class="logo">
        <img
          class="logo__mark"
          src="/images/fortuna-logo.png"
          alt=""
          width="48"
          height="48"
        >
        <div>
          <div class="logo__text">ФК Фортуна Минск</div>
        </div>
      </a>
      <div class="header-tagline">Когда игра в радость</div>
    </div>
    <button class="nav-toggle" aria-label="Меню">
      <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"/></svg>
    </button>
    <nav class="nav">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Главная</a>
      <a href="/blog" class="<%= currentPath.startsWith('/blog') ? 'active' : '' %>">Новости</a>
      <a href="/vizitka" class="<%= currentPath === '/vizitka' ? 'active' : '' %>">Визитка</a>
      <a href="/gruppy" class="<%= currentPath.startsWith('/gruppy') ? 'active' : '' %>">Группы</a>
      <a href="/raspisanie" class="<%= currentPath === '/raspisanie' ? 'active' : '' %>">Расписание</a>
      <a href="/vospitanniki" class="<%= currentPath.startsWith('/vospitanniki') ? 'active' : '' %>">Воспитанники</a>
      <a href="/foto" class="<%= currentPath.startsWith('/foto') || currentPath.startsWith('/arhiv') || currentPath.startsWith('/fotogalereya') ? 'active' : '' %>">Фото</a>
    </nav>
  </div>
</header>
